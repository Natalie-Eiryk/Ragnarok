# Cloudflare Tunnel Configuration for LUMI-OS
# Copy to: C:\Users\<username>\.cloudflared\config.yml
#
# Replace:
#   - <TUNNEL-ID> with your tunnel ID from 'cloudflared tunnel create'
#   - <username> with your Windows username

tunnel: <TUNNEL-ID>
credentials-file: C:\Users\<username>\.cloudflared\<TUNNEL-ID>.json

# Ingress rules - how to route traffic
ingress:
  # Main LUMI endpoint - routes to Bifrost WebSocket server
  - hostname: lumi.natalie-eiryk.com
    service: http://localhost:8765
    originRequest:
      # WebSocket support
      noTLSVerify: true
      connectTimeout: 30s
      # Keep connections alive for WebSocket
      keepAliveTimeout: 90s
      keepAliveConnections: 100

  # Health check endpoint (optional)
  - hostname: lumi.natalie-eiryk.com
    path: /health
    service: http://localhost:8765/health

  # Catch-all - return 404 for unmatched routes
  - service: http_status:404

# Logging (optional but helpful for debugging)
loglevel: info
logfile: C:\Users\<username>\.cloudflared\cloudflared.log

# Metrics (optional - for monitoring)
metrics: localhost:60123
